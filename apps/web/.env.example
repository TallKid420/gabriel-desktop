# Gabriel Desktop — web app environment
#
# Base URL of the gabriel-core API (must include the /api/v1 prefix).
# The gateway client falls back to NEXT_PUBLIC_GATEWAY_URL + /api/v1, and
# ultimately to http://localhost:8000/api/v1 when nothing is set.
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Optional: host of the gabriel-core gateway without the /api/v1 suffix.
# Only used when NEXT_PUBLIC_API_URL is not provided.
# NEXT_PUBLIC_GATEWAY_URL=http://localhost:8000

# Optional: set to "true" to run the UI against in-memory mock data
# instead of a live backend.
# NEXT_PUBLIC_USE_MOCK=false
