# Copy to .env.local to run the web app against the live Gateway.
#
# Auth is migrated to the live Gateway/Identity chain in M1. Every other domain
# (chat, agents, documents, ...) still serves mock data until later milestones,
# so we flip auth on per-domain rather than with a single global switch.

NEXT_PUBLIC_GATEWAY_URL=http://localhost:8080

# Turn the auth domain live (login/session/logout hit the Gateway).
NEXT_PUBLIC_LIVE_AUTH=true

# Global mock switch for un-migrated domains. Leave 'true' during M1.
NEXT_PUBLIC_USE_MOCK=true
